{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_appName__",
  "version": "1.3.0",
  "description": "__MSG_appDesc__",
  "author": "Zakhar Lebediuk",
  "homepage_url": "https://prorok1015.github.io/ado-atlas/",
  "permissions": ["storage", "identity", "alarms", "notifications"],
  "host_permissions": [
    "https://dev.azure.com/*",
    "https://app.vssps.visualstudio.com/*",
    "https://login.microsoftonline.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://www.google-analytics.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": { "extension_pages": "script-src 'self'; object-src 'none'; connect-src https://dev.azure.com https://app.vssps.visualstudio.com https://login.microsoftonline.com https://generativelanguage.googleapis.com https://api.openai.com" },
  "action": {
    "default_title": "ADO Atlas",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
